# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ── Dependencies ─────────────────────────────────────────
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ── Testing ───────────────────────────────────────────────
/coverage

# ── Next.js ───────────────────────────────────────────────
/.next/
/out/
/build

# ── Prisma ────────────────────────────────────────────────
# Keep schema.prisma and migrations, ignore generated client
/prisma/generated/
# Ignore SQLite local dev database (use PostgreSQL in prod)
*.db
*.db-journal
*.db-shm
*.db-wal

# ── Environment & Secrets ─────────────────────────────────
# NEVER commit credentials, API keys, or database URLs
.env
.env.local
.env.development
.env.production
.env.test
.env*.local
*.pem
*.key
*.cert

# ── Electron Build Artifacts ──────────────────────────────
/dist-electron/
/release/
/electron-dist/
*.exe
*.dmg
*.AppImage
*.snap
*.deb
*.rpm
out/

# ── Logs & Debug ─────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# ── OS & Editor ───────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# ── TypeScript ────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ── Vercel / Deployment ───────────────────────────────────
.vercel

# ── Misc ──────────────────────────────────────────────────
# Ignore any local backup or client data files
*.bak
*.tmp
/uploads/
/public/uploads/
