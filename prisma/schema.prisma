datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ==========================================
// PRISMA SYSTEM ENUMS
// ==========================================

enum EmployeeRole {
  SUPER_ADMIN
  HOSPITAL_ADMIN
  EMPLOYEE
}

enum PaymentMode {
  CASH
  UPI
  CARD
  CHEQUE
  BANK_TRANSFER
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum BloodGroup {
  A_POSITIVE
  A_NEGATIVE
  B_POSITIVE
  B_NEGATIVE
  AB_POSITIVE
  AB_NEGATIVE
  O_POSITIVE
  O_NEGATIVE
}

enum OTType {
  MINOR
  MAJOR
}

enum LaboratoryStatus {
  SCHEDULED
  SAMPLE_COLLECTED
  COMPLETED
  CANCELLED
}

enum RadiologyStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

enum InvoiceStatus {
  PENDING
  PAID
  PARTIALLY_PAID
  CANCELLED
  REFUNDED
}

enum BillingStatus {
  PENDING
  INVOICED
  WAIVED
  CANCELLED
}

enum PharmacyCustomerType {
  WALK_IN
  PATIENT
}

enum RoomType {
  GENERAL_WARD
  ICU
  SEMI_PRIVATE
  PRIVATE
}

enum BedStatus {
  AVAILABLE
  OCCUPIED
  MAINTENANCE
}

enum DeliveryType {
  NORMAL
  CESAREAN
  STILL_BIRTH
}

enum DeathLocationType {
  EMERGENCY
  IPD
  DEAD_ON_ARRIVAL
}

enum MaritalStatus {
  SINGLE
  MARRIED
  DIVORCED
  WIDOWED
}

enum ChargeSourceModule {
  OPD
  IPD
  OT
  LABORATORY
  RADIOLOGY
  PHARMACY
  MANUAL
}

// ==========================================
// 1. TENANT, SEQUENCES & CONFIGURATIONS
// ==========================================

model Hospital {
  id                    String    @id @default(uuid())
  name                  String    @db.VarChar(150)
  code                  String    @unique @db.VarChar(10)
  phone                 String    @db.VarChar(20)
  email                 String    @db.VarChar(100)
  address               String    @db.Text
  gstNumber             String?   @db.VarChar(50)
  registrationNumber    String?   @db.VarChar(100)
  website               String?   @db.VarChar(150)
  logoUrl               String?   @db.Text
  footerText            String?   @db.Text
  stateInsuranceLicense String?   @db.VarChar(100)
  currentVersion        String    @default("2.0.0") @db.VarChar(20)

  // Standard Metadata
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  createdBy             String?   @db.Uuid
  updatedBy             String?   @db.Uuid
  isDeleted             Boolean   @default(false)
  deletedAt             DateTime?
  deletedBy             String?   @db.Uuid

  // Tenant Back-Relations
  employees             Employee[]
  patients              Patient[]
  opdConsultations      OPDConsultation[]
  ipdAdmissions         IPDAdmission[]
  invoices              Invoice[]
  labOrders             LabTestOrder[]
  pharmacyInvoices      PharmacyInvoice[]
  otBookings            OperationTheater[]
  births                BirthRegistration[]
  deaths                DeathRegistration[]
  printTemplates        PrintTemplate[]
  deposits              PatientDeposit[]

  @@map("hospitals")
}

model SystemSetting {
  id           String    @id @default(uuid())
  settingKey   String    @unique @db.VarChar(100)
  settingValue String    @db.Text
  dataType     String    @default("STRING") @db.VarChar(30) // "STRING", "INTEGER", "BOOLEAN", "JSON"
  category     String    @default("GENERAL") @db.VarChar(50)
  description  String?   @db.Text

  // Standard Metadata
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  createdBy    String?   @db.Uuid
  updatedBy    String?   @db.Uuid
  isDeleted    Boolean   @default(false)
  deletedAt    DateTime?
  deletedBy    String?   @db.Uuid

  @@map("system_settings")
}

model Sequence {
  sequenceName    String   @id @db.VarChar(100)
  currentValue    BigInt   @default(0)
  prefix          String   @db.VarChar(20)
  paddingLength   Int      @default(5)
  isActive        Boolean  @default(true)
  description     String?  @db.Text
  lastGeneratedAt DateTime @default(now()) @updatedAt

  @@map("sequences")
}

// ==========================================
// 2. STAFF, IDENTITY & SESSION REGISTRY
// ==========================================

model Department {
  id              String            @id @default(uuid())
  name            String            @db.VarChar(100)
  code            String            @unique @db.VarChar(10)
  description     String?           @db.Text

  // Relationships
  employees       Employee[]
  opdConsultations OPDConsultation[]
  ipdAdmissions   IPDAdmission[]
  otBookings      OperationTheater[]
  consultations   IPDConsultation[]

  // Standard Metadata
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  createdBy       String?           @db.Uuid
  updatedBy       String?           @db.Uuid
  isDeleted       Boolean           @default(false)
  deletedAt       DateTime?
  deletedBy       String?           @db.Uuid

  @@map("departments")
}

model Employee {
  id                String            @id @default(uuid())
  name              String            @db.VarChar(100) @default("Employee")
  employeeCode      String            @unique @db.VarChar(50)
  email             String            @unique @db.VarChar(100)
  passwordHash      String            @db.VarChar(255)
  role              EmployeeRole
  designation       String            @db.VarChar(100)
  departmentId      String?
  hospitalId        String
  mobileNumber      String            @db.VarChar(20)
  joiningDate       DateTime
  isActive          Boolean           @default(true)
  failedLoginCount  Int               @default(0)
  lockedUntil       DateTime?
  passwordChangedAt DateTime          @default(now())
  lastLoginAt       DateTime?
  lastLoginIp       String?           @db.VarChar(45)

  // Standard Metadata
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  createdBy         String?           @db.Uuid
  updatedBy         String?           @db.Uuid
  isDeleted         Boolean           @default(false)
  deletedAt         DateTime?
  deletedBy         String?           @db.Uuid

  // Relationships
  hospital          Hospital          @relation(fields: [hospitalId], references: [id], onDelete: Restrict)
  department        Department?       @relation(fields: [departmentId], references: [id], onDelete: Restrict)
  doctor            Doctor?
  sessions          Session[]
  permissions       Permission[]

  // Action Registry Logging Links
  cancelledOpds     OPDConsultation[] @relation("OPDCancelledBy")
  cancelledIpds     IPDAdmission[]    @relation("IPDCancelledBy")
  completedOts      OperationTheater[] @relation("OTCompletedBy")
  cancelledOts      OperationTheater[] @relation("OTCancelledBy")
  paymentsReceived  Payment[]         @relation("PaymentReceivedBy")
  refundsProcessed  Refund[]          @relation("RefundProcessedBy")
  pharmacyPurchases PharmacyPurchaseOrder[] @relation("PharmacyPurchaseReceivedBy")
  pharmacyReceived  PharmacyInvoice[] @relation("PharmacyInvoiceReceivedBy")
  pharmacyCancelled PharmacyInvoice[] @relation("PharmacyInvoiceCancelledBy")
  stockAdjustments  PharmacyStockAdjustment[]
  transfersManaged  BedTransferHistory[] @relation("BedTransferBy")
  cancelledInvoices Invoice[]         @relation("InvoiceCancelledBy")
  docAssignments    DoctorAssignmentHistory[] @relation("DocAssignChangedBy")
  ipdDischarges     IPDAdmission[]    @relation("IPDDischargedBy")
  audits            Audit[]
  printHistories    PrintHistory[]    @relation("PrintedByEmployee")
  handoversReceived IPDHandover[]

  @@index([email])
  @@index([role])
  @@index([hospitalId])
  @@map("employees")
}

model Doctor {
  id                 String            @id // Linked 1:1 with Employee.id
  registrationNumber String            @unique @db.VarChar(50)
  qualification      String            @db.VarChar(150)
  specialization     String            @db.VarChar(100)
  consultationFee    Decimal           @db.Decimal(12, 2)
  roomNumber         String?           @db.VarChar(20)
  dutySchedule       Json?

  // Standard Metadata
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  createdBy          String?           @db.Uuid
  updatedBy          String?           @db.Uuid
  isDeleted          Boolean           @default(false)
  deletedAt          DateTime?
  deletedBy          String?           @db.Uuid

  // Relationships
  employee           Employee          @relation(fields: [id], references: [id], onDelete: Cascade)
  opdConsultations   OPDConsultation[]
  ipdAdmissions      IPDAdmission[]
  assignedOts        OperationTheater[] @relation("OTPrimarySurgeon")
  assistedOts        OperationTheater[] @relation("OTAssistantSurgeon")
  birthsAttended     BirthRegistration[]
  deathsAttended     DeathRegistration[]
  labOrders          LabTestOrder[]
  radiologyOrders    RadiologyScanOrder[]
  assignmentFrom     DoctorAssignmentHistory[] @relation("DocAssignPrev")
  assignmentTo       DoctorAssignmentHistory[] @relation("DocAssignNew")
  referredAdmissions IPDAdmission[]            @relation("IPDReferredBy")
  rounds             IPDDoctorRound[]
  consultations      IPDConsultation[]

  @@map("doctors")
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  expiresAt DateTime
  ipAddress String?  @db.VarChar(45)
  userAgent String?  @db.Text
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      Employee @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model Permission {
  id        String   @id @default(uuid())
  userId    String
  module    String   @db.VarChar(50)
  action    String   @db.VarChar(50)
  isAllowed Boolean  @default(false)

  // Standard Metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?  @db.Uuid
  updatedBy String?  @db.Uuid

  user      Employee @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, module, action])
  @@map("permissions")
}

// ==========================================
// 3. PATIENT REGISTRY (NORMALIZED)
// ==========================================

model Patient {
  id                String                 @id @default(uuid())
  uhid              String                 @unique @db.VarChar(30)
  name              String                 @db.VarChar(150)
  phone             String                 @db.VarChar(20)
  alternatePhone    String?                @db.VarChar(20)
  email             String?                @db.VarChar(100)
  dob               DateTime               @db.Date
  gender            Gender
  bloodGroup        BloodGroup?
  aadhaarNumber     String?                @unique @db.VarChar(12)
  occupation        String?                @db.VarChar(100)
  photoUrl          String?                @db.Text
  maritalStatus     MaritalStatus?
  nationality       String?                @default("Indian") @db.VarChar(100)
  remarks           String?                @db.Text
  hospitalId        String
  version           Int                    @default(1)

  // Standard Metadata
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  createdBy         String?                @db.Uuid
  updatedBy         String?                @db.Uuid
  isDeleted         Boolean                @default(false)
  deletedAt         DateTime?
  deletedBy         String?                @db.Uuid

  // Relationships
  hospital          Hospital               @relation(fields: [hospitalId], references: [id], onDelete: Restrict)
  address           PatientAddress?
  emergencyContact  PatientEmergencyContact?
  referrals         PatientReferral[]
  opdConsultations  OPDConsultation[]
  ipdAdmissions     IPDAdmission[]
  otBookings        OperationTheater[]
  labOrders         LabTestOrder[]
  radiologyOrders   RadiologyScanOrder[]
  billableCharges   BillableCharge[]
  invoices          Invoice[]
  pharmacyInvoices  PharmacyInvoice[]
  motherBirths      BirthRegistration[]    @relation("MotherPatient")
  deaths            DeathRegistration[]
  deposits          PatientDeposit[]

  @@index([uhid])
  @@index([phone])
  @@index([aadhaarNumber])
  @@index([name])
  @@index([hospitalId])
  @@index([createdAt])
  @@map("patients")
}

model PatientAddress {
  id          String   @id @default(uuid())
  patientId   String   @unique
  addressLine String   @db.Text
  city        String   @db.VarChar(100)
  state       String   @db.VarChar(100)
  pincode     String   @db.VarChar(15)

  // Standard Metadata
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdBy   String?  @db.Uuid
  updatedBy   String?  @db.Uuid
  isDeleted   Boolean  @default(false)
  deletedAt   DateTime?
  deletedBy   String?  @db.Uuid

  patient     Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@map("patient_addresses")
}

model PatientEmergencyContact {
  id        String   @id @default(uuid())
  patientId String   @unique
  name      String   @db.VarChar(150)
  phone     String   @db.VarChar(20)
  relation  String   @db.VarChar(50)

  // Standard Metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?  @db.Uuid
  updatedBy String?  @db.Uuid
  isDeleted Boolean  @default(false)
  deletedAt DateTime?
  deletedBy String?  @db.Uuid

  patient   Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@map("patient_emergency_contacts")
}

model PatientReferral {
  id                 String   @id @default(uuid())
  patientId          String
  referralType       String   @db.VarChar(50)  // "DOCTOR", "CLINIC", "HOSPITAL", "SELF"
  referralName       String   @db.VarChar(150)
  referralNotes      String?  @db.Text

  // Standard Metadata
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  createdBy          String?  @db.Uuid
  updatedBy          String?  @db.Uuid
  isDeleted          Boolean  @default(false)
  deletedAt          DateTime?
  deletedBy          String?  @db.Uuid

  patient            Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@map("patient_referrals")
}

// ==========================================
// 4. WARD & BED ALLOCATION
// ==========================================

model Building {
  id        String   @id @default(uuid())
  name      String   @db.VarChar(100)
  code      String   @unique @db.VarChar(20)
  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  floors    Floor[]

  @@map("buildings")
}

model Floor {
  id         String   @id @default(uuid())
  name       String   @db.VarChar(100)
  buildingId String
  isDeleted  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  building   Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  wards      Ward[]

  @@map("floors")
}

model Ward {
  id        String   @id @default(uuid())
  name      String   @db.VarChar(100)
  code      String   @unique @db.VarChar(20)
  floorId   String
  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  floor     Floor    @relation(fields: [floorId], references: [id], onDelete: Cascade)
  rooms     BedRoom[]

  @@map("wards")
}

model BedRoom {
  id           String    @id @default(uuid())
  roomNumber   String    @unique @db.VarChar(20)
  roomType     RoomType
  chargePerDay Decimal   @db.Decimal(12, 2)
  wardId       String

  // Standard Metadata
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  createdBy    String?   @db.Uuid
  updatedBy    String?   @db.Uuid
  isDeleted    Boolean   @default(false)
  deletedAt    DateTime?
  deletedBy    String?   @db.Uuid

  // Relationships
  ward         Ward      @relation(fields: [wardId], references: [id], onDelete: Cascade)
  beds         Bed[]

  @@map("bed_rooms")
}

model Bed {
  id           String               @id @default(uuid())
  roomId       String
  bedNumber    String               @db.VarChar(20)
  status       BedStatus            @default(AVAILABLE)

  // Standard Metadata
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  createdBy    String?              @db.Uuid
  updatedBy    String?              @db.Uuid
  isDeleted    Boolean              @default(false)
  deletedAt    DateTime?
  deletedBy    String?              @db.Uuid

  // Relationships
  room         BedRoom              @relation(fields: [roomId], references: [id], onDelete: Cascade)
  admissions   IPDAdmission[]
  transfersFrom BedTransferHistory[] @relation("TransferBedPrev")
  transfersTo   BedTransferHistory[] @relation("TransferBedNew")

  @@unique([roomId, bedNumber])
  @@map("beds")
}

model BedTransferHistory {
  id             String       @id @default(uuid())
  ipdAdmissionId String
  previousBedId  String?
  newBedId       String
  transferDate   DateTime     @default(now())
  transferReason String?      @db.Text
  transferredBy  String

  // Standard Metadata
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  createdBy      String?      @db.Uuid
  updatedBy      String?      @db.Uuid
  isDeleted      Boolean      @default(false)
  deletedAt      DateTime?
  deletedBy      String?      @db.Uuid

  // Relationships
  ipdAdmission   IPDAdmission @relation(fields: [ipdAdmissionId], references: [id], onDelete: Cascade)
  previousBed    Bed?         @relation("TransferBedPrev", fields: [previousBedId], references: [id], onDelete: Restrict)
  newBed         Bed          @relation("TransferBedNew", fields: [newBedId], references: [id], onDelete: Restrict)
  manager        Employee     @relation("BedTransferBy", fields: [transferredBy], references: [id], onDelete: Restrict)

  @@map("bed_transfer_history")
}

// ==========================================
// 5. CLINICAL VISIT LIFE-CYCLES
// ==========================================

model OPDConsultation {
  id                 String               @id @default(uuid())
  opdId              String               @unique @db.VarChar(30)
  patientId          String
  doctorId           String
  departmentId       String
  hospitalId         String
  consultationDate   DateTime
  depositAmount      Decimal              @default(0.00) @db.Decimal(12, 2)
  originalFee        Decimal              @db.Decimal(12, 2)
  appliedFee         Decimal              @db.Decimal(12, 2)
  overrideReason     String?              @db.Text
  tokenNumber        Int
  version            Int                  @default(1)
  symptoms           String?              @db.Text

  // Lifecycle Cancellations
  cancelledAt        DateTime?
  cancelledBy        String?
  cancellationReason String?              @db.Text

  // Standard Metadata
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  createdBy          String?              @db.Uuid
  updatedBy          String?              @db.Uuid
  isDeleted          Boolean              @default(false)
  deletedAt          DateTime?
  deletedBy          String?              @db.Uuid

  // Relationships
  hospital           Hospital             @relation(fields: [hospitalId], references: [id], onDelete: Restrict)
  patient            Patient              @relation(fields: [patientId], references: [id], onDelete: Restrict)
  doctor             Doctor               @relation(fields: [doctorId], references: [id], onDelete: Restrict)
  department         Department           @relation(fields: [departmentId], references: [id], onDelete: Restrict)
  canceller          Employee?            @relation("OPDCancelledBy", fields: [cancelledBy], references: [id], onDelete: Restrict)
  labOrders          LabTestOrder[]
  radiologyOrders    RadiologyScanOrder[]
  otBookings         OperationTheater[]
  deposits           PatientDeposit[]

  @@index([opdId])
  @@index([patientId])
  @@index([doctorId])
  @@index([consultationDate])
  @@index([hospitalId])
  @@index([doctorId, consultationDate])
  @@map("opd_consultations")
}

model IPDAdmission {
  id                        String                    @id @default(uuid())
  ipdId                     String                    @unique @db.VarChar(30)
  patientId                 String
  bedId                     String
  primaryDoctorId           String
  departmentId              String
  hospitalId                String
  admissionDate             DateTime
  dischargeDate             DateTime?
  dischargeSummary          String?                   @db.Text
  dischargeBy               String?
  isDeceased                Boolean                   @default(false)
  version                   Int                       @default(1)

  // Newly Added Stay Management Fields
  codeStatus                String?                   @default("FULL_CODE") // FULL_CODE, DNR
  isolationStatus           String?                   @default("NONE")      // NONE, CONTACT, DROPLET, AIRBORNE
  referredByDoctorId        String?
  isMLC                     Boolean                   @default(false)
  mlcNumber                 String?
  admissionSource           String?                   // DIRECT, OPD_REFERRAL, EMERGENCY, DOCTOR_REFERRAL
  admissionCategory         String?                   @default("GENERAL")   // GENERAL, PRIVATE, INSURANCE, CORPORATE, GOVERNMENT_SCHEME
  initialDepositRequired    Float?                    @default(0)
  admissionReason           String?                   @db.Text
  status                    String                    @default("ADMITTED")  // ADMITTED, TRANSFERRED, DISCHARGED, LAMA, DAMA, REFERRED, EXPIRED
  dischargeType             String?
  finalDiagnosis            String?
  treatmentSummary          String?                   @db.Text
  conditionAtDischarge      String?
  followUpInstructions      String?                   @db.Text

  // Lifecycle Cancellations
  cancelledAt               DateTime?
  cancelledBy               String?
  cancellationReason        String?                   @db.Text

  // Standard Metadata
  createdAt                 DateTime                  @default(now())
  updatedAt                 DateTime                  @updatedAt
  createdBy                 String?                   @db.Uuid
  updatedBy                 String?                   @db.Uuid
  isDeleted                 Boolean                   @default(false)
  deletedAt                 DateTime?
  deletedBy                 String?                   @db.Uuid

  // Relationships
  hospital                  Hospital                  @relation(fields: [hospitalId], references: [id], onDelete: Restrict)
  patient                   Patient                   @relation(fields: [patientId], references: [id], onDelete: Restrict)
  bed                       Bed                       @relation(fields: [bedId], references: [id], onDelete: Restrict)
  primaryDoctor             Doctor                    @relation(fields: [primaryDoctorId], references: [id], onDelete: Restrict)
  department                Department                @relation(fields: [departmentId], references: [id], onDelete: Restrict)
  canceller                 Employee?                 @relation("IPDCancelledBy", fields: [cancelledBy], references: [id], onDelete: Restrict)
  discharger                Employee?                 @relation("IPDDischargedBy", fields: [dischargeBy], references: [id], onDelete: Restrict)
  referredByDoctor          Doctor?                   @relation("IPDReferredBy", fields: [referredByDoctorId], references: [id], onDelete: Restrict)
  doctorAssignments         DoctorAssignmentHistory[]
  bedTransfers              BedTransferHistory[]
  otBookings                OperationTheater[]
  births                    BirthRegistration[]
  labOrders                 LabTestOrder[]
  radiologyOrders           RadiologyScanOrder[]
  deaths                    DeathRegistration[]
  dischargeSummaryRevisions DischargeSummaryRevision[]

  // Newly Added Stay Management Relations
  attendants                IPDAttendant[]
  timelineEvents            IPDTimelineEvent[]
  vitals                    IPDVitals[]
  rounds                    IPDDoctorRound[]
  progressNotes             IPDProgressNote[]
  treatmentOrders           IPDTreatmentOrder[]
  intakeOutputs             IPDIntakeOutput[]
  consultations             IPDConsultation[]
  handovers                 IPDHandover[]
  nursingTasks              IPDNursingTask[]
  attachments               IPDClinicalAttachment[]

  @@index([ipdId])
  @@index([patientId])
  @@index([bedId])
  @@index([admissionDate])
  @@index([hospitalId])
  @@map("ipd_admissions")
}

// ----------------------------------------------------
// NEW INPATIENT CLINICAL MODELS
// ----------------------------------------------------

model IPDAttendant {
  id             String       @id @default(uuid())
  ipdAdmissionId String
  name           String
  relationship   String
  mobile         String
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  isDeleted      Boolean      @default(false)
  ipdAdmission   IPDAdmission @relation(fields: [ipdAdmissionId], references: [id], onDelete: Restrict)

  @@index([ipdAdmissionId])
  @@map("ipd_attendants")
}

model IPDTimelineEvent {
  id             String       @id @default(uuid())
  ipdAdmissionId String
  eventType      String       // ADMISSION, VITALS, ROUND, NOTE, ORDER, INTAKE_OUTPUT, CONSULT, HANDOVER, BED_TRANSFER, DISCHARGE
  description    String       @db.Text
  recordedBy     String
  createdAt      DateTime     @default(now())
  ipdAdmission   IPDAdmission @relation(fields: [ipdAdmissionId], references: [id], onDelete: Restrict)

  @@index([ipdAdmissionId])
  @@map("ipd_timeline_events")
}

model IPDVitals {
  id             String       @id @default(uuid())
  ipdAdmissionId String
  temperature    Float?       // Temp (°F)
  pulse          Int?         // Pulse (bpm)
  systolicBP     Int?         // Systolic BP
  diastolicBP    Int?         // Diastolic BP
  spo2           Int?         // SpO2 (%)
  respiratoryRate Int?        // Resp Rate
  weight         Float?       // Weight (kg)
  height         Float?       // Height (cm)
  bloodSugar     Int?         // RBS
  recordedBy     String
  createdAt      DateTime     @default(now())
  isDeleted      Boolean      @default(false)
