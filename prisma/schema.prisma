model OperationTheater {
  id                 String       @id @default(uuid())
  otId               String       @unique @db.VarChar(30)
  ipdAdmissionId     String?
  opdConsultationId  String?
  patientId          String
  hospitalId         String
  departmentId       String
  operationType      OTType
  operationName      String       @db.VarChar(150)
  diagnosis          String       @db.Text
  scheduledDate      DateTime
  remarks            String?      @db.Text

  // Timestamps
  completedAt        DateTime?
  completedBy        String?
  cancelledAt        DateTime?
  cancelledBy        String?
  cancellationReason String?      @db.Text

  // Standard Metadata
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  createdBy          String?      @db.Uuid
  updatedBy          String?      @db.Uuid
  isDeleted          Boolean      @default(false)
  deletedAt          DateTime?
  deletedBy          String?      @db.Uuid

  // Relationships
  hospital           Hospital     @relation(fields: [hospitalId], references: [id], onDelete: Restrict)
  ipdAdmission       IPDAdmission? @relation(fields: [ipdAdmissionId], references: [id], onDelete: Cascade)
  opdConsultation    OPDConsultation? @relation(fields: [opdConsultationId], references: [id], onDelete: SetNull)
  patient            Patient      @relation(fields: [patientId], references: [id], onDelete: Restrict)
  department         Department   @relation(fields: [departmentId], references: [id], onDelete: Restrict)
  completer          Employee?    @relation("OTCompletedBy", fields: [completedBy], references: [id], onDelete: Restrict)
  canceller          Employee?    @relation("OTCancelledBy", fields: [cancelledBy], references: [id], onDelete: Restrict)
  primarySurgeon     Doctor       @relation("OTPrimarySurgeon", fields: [primarySurgeonId], references: [id], onDelete: Restrict)
  assistantSurgeon   Doctor?      @relation("OTAssistantSurgeon", fields: [assistantSurgeonId], references: [id], onDelete: Restrict)
  primarySurgeonId   String
  assistantSurgeonId String?
  procedureCatalogId String?
  procedureCatalog   ChargeCatalog? @relation("OTProcedureCatalog", fields: [procedureCatalogId], references: [id], onDelete: SetNull)
  revisions          OperationTheaterRevision[]

  @@index([otId])
  @@index([ipdAdmissionId])
  @@index([opdConsultationId])
  @@index([scheduledDate])
  @@index([hospitalId])
  @@map("operation_theaters")
}

model OperationTheaterRevision {
  id                 String       @id @default(uuid())
  operationTheaterId String
  revisionNumber     Int
  operationName      String       @db.VarChar(150)
  diagnosis          String       @db.Text
  primarySurgeonId   String
  assistantSurgeonId String?
  departmentId       String
  remarks            String?      @db.Text
  editedAt           DateTime     @default(now())
  editedBy           String

  // Relationships
  operationTheater   OperationTheater @relation(fields: [operationTheaterId], references: [id], onDelete: Cascade)

  @@index([operationTheaterId])
  @@map("operation_theater_revisions")
}

