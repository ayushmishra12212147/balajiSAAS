  // Standard Metadata
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  createdBy    String?        @db.Uuid
  updatedBy    String?        @db.Uuid
  isDeleted    Boolean        @default(false)
  deletedAt    DateTime?
  deletedBy    String?        @db.Uuid

  // Relationships
  orders       LabTestOrder[]

  @@map("lab_test_catalogs")
}

model LabTestOrder {
  id                 String           @id @default(uuid())
  patientId          String
  testCatalogId      String
  orderedByDoctorId  String
  opdConsultationId  String?
  ipdAdmissionId     String?
  billableChargeId   String?
  hospitalId         String
  status             LaboratoryStatus @default(SCHEDULED)
  sampleCollectedAt  DateTime?
  sampleCollectedBy  String?          @db.Uuid
  cancelledAt        DateTime?
  cancelledBy        String?          @db.Uuid
  cancellationReason String?          @db.Text
  technicianId       String?          @db.Uuid
  verifiedById       String?          @db.Uuid
  remarks            String?          @db.Text
  completedAt        DateTime?
  completedBy        String?

  // Standard Metadata
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  createdBy          String?          @db.Uuid
  updatedBy          String?          @db.Uuid
  isDeleted          Boolean          @default(false)
  deletedAt          DateTime?
  deletedBy          String?          @db.Uuid

  // Relationships
  hospital           Hospital         @relation(fields: [hospitalId], references: [id], onDelete: Restrict)
  patient            Patient          @relation(fields: [patientId], references: [id], onDelete: Restrict)
  testCatalog        LabTestCatalog   @relation(fields: [testCatalogId], references: [id], onDelete: Restrict)
  orderedByDoctor    Doctor           @relation(fields: [orderedByDoctorId], references: [id], onDelete: Restrict)
  opdConsultation    OPDConsultation? @relation(fields: [opdConsultationId], references: [id], onDelete: SetNull)
  ipdAdmission       IPDAdmission?    @relation(fields: [ipdAdmissionId], references: [id], onDelete: SetNull)
  results            LabTestResult[]
  revisions          LabResultRevision[]

  @@index([patientId])
  @@index([status])
  @@index([hospitalId])
  @@index([patientId, createdAt])
  @@map("lab_test_orders")
}

model LabTestResult {
  id             String           @id @default(uuid())
  testOrderId    String
  parameterName  String           @db.VarChar(100)
  parameterValue String           @db.VarChar(100)
  referenceRange String?          @db.VarChar(100)
  unit           String?          @db.VarChar(20)
  status         String           @default("DRAFT") @db.VarChar(30) // "DRAFT", "FINALIZED"

  // Standard Metadata
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  createdBy      String?          @db.Uuid
  updatedBy      String?          @db.Uuid
  isDeleted      Boolean          @default(false)
  deletedAt      DateTime?
  deletedBy      String?          @db.Uuid

  // Relationships
  testOrder      LabTestOrder     @relation(fields: [testOrderId], references: [id], onDelete: Cascade)

  @@unique([testOrderId, parameterName])
  @@map("lab_test_results")
}

model RadiologyScanCatalog {
