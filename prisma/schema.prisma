  // Relationships
  ipdAdmission       IPDAdmission @relation(fields: [ipdAdmissionId], references: [id], onDelete: Cascade)

  @@index([ipdAdmissionId])
  @@map("discharge_summary_revisions")
}

// ==========================================
// 10. PHARMACY INVENTORY & SALES
// ==========================================

model Medicine {
  id                  String                 @id @default(uuid())
  code                String                 @unique @db.VarChar(30)
  name                String                 @db.VarChar(150)
  genericName         String                 @db.VarChar(150)
  category            String                 @db.VarChar(50)
  form                String                 @db.VarChar(50)
  standardSellingPrice Decimal                @db.Decimal(12, 2)
  brand               String                 @db.VarChar(100) @default("Generic")
  unit                String                 @db.VarChar(30) @default("Tablets")
  hsnCode             String?                @db.VarChar(30)
  gstPercentage       Decimal                @db.Decimal(5, 2) @default(0.00)
  purchasePrice       Decimal                @db.Decimal(12, 2) @default(0.00)
  sellingPrice        Decimal                @db.Decimal(12, 2) @default(0.00)
  minimumStock        Int                    @default(0)
  isActive            Boolean                @default(true)
  isExpirable         Boolean                @default(true)

  // Standard Metadata
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
  createdBy           String?                @db.Uuid
  updatedBy           String?                @db.Uuid
  isDeleted           Boolean                @default(false)
  deletedAt           DateTime?
  deletedBy           String?                @db.Uuid

  // Relationships
  stock               MedicineStock[]
  purchaseItems       PharmacyPurchaseItem[]
  invoiceItems        PharmacyInvoiceItem[]
  adjustments         PharmacyStockAdjustment[]
  returnItems         PharmacyReturnItem[]

  @@index([name])
  @@index([genericName])
  @@index([code])
  @@map("medicines")
}

model MedicineStock {
  id              String    @id @default(uuid())
  medicineId      String
  batchNumber     String    @db.VarChar(50)
  expiryDate      DateTime? @db.Date
  currentQuantity Int
  purchaseRate    Decimal   @db.Decimal(12, 2)
  sellingRate     Decimal   @db.Decimal(12, 2)
  gstPercentage   Decimal   @db.Decimal(5, 2) @default(0.00)
  version         Int       @default(1)

  // Standard Metadata
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  createdBy       String?   @db.Uuid
  updatedBy       String?   @db.Uuid
  isDeleted       Boolean   @default(false)
  deletedAt       DateTime?
  deletedBy       String?   @db.Uuid

  // Relationships
  medicine        Medicine  @relation(fields: [medicineId], references: [id], onDelete: Cascade)

  @@unique([medicineId, batchNumber])
  @@index([medicineId])
  @@index([expiryDate])
  @@map("medicine_stocks")
}

model PharmacyPurchaseOrder {
  id            String                 @id @default(uuid())
  invoiceNumber String                 @db.VarChar(50)
  supplierName  String                 @db.VarChar(150)
  orderDate     DateTime               @db.Date
  totalCost     Decimal                @db.Decimal(12, 2)
  receivedBy    String
  remarks       String?                @db.Text

  // Standard Metadata
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  createdBy     String?                @db.Uuid
  updatedBy     String?                @db.Uuid
  isDeleted     Boolean                @default(false)
  deletedAt     DateTime?
  deletedBy     String?                @db.Uuid

  // Relationships
  recipient     Employee               @relation("PharmacyPurchaseReceivedBy", fields: [receivedBy], references: [id], onDelete: Restrict)
  items         PharmacyPurchaseItem[]

  @@map("pharmacy_purchase_orders")
}

model PharmacyPurchaseItem {
  id              String                @id @default(uuid())
  purchaseOrderId String
  medicineId      String
  batchNumber     String                @db.VarChar(50)
  expiryDate      DateTime?             @db.Date
  quantityReceived Int
  unitCost        Decimal               @db.Decimal(12, 2)
  purchaseRate    Decimal               @db.Decimal(12, 2) @default(0.00)
  sellingRate     Decimal               @db.Decimal(12, 2) @default(0.00)
  gstPercentage   Decimal               @db.Decimal(5, 2) @default(0.00)

  // Standard Metadata
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  createdBy       String?               @db.Uuid
  updatedBy       String?               @db.Uuid
  isDeleted       Boolean               @default(false)
  deletedAt       DateTime?
  deletedBy       String?               @db.Uuid

  // Relationships
  purchaseOrder   PharmacyPurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  medicine        Medicine              @relation(fields: [medicineId], references: [id], onDelete: Restrict)

  @@map("pharmacy_purchase_items")
}

model PharmacyInvoice {
  id                    String                @id @default(uuid())
  pharmacyInvoiceNumber String                @unique @db.VarChar(30)
  customerType          PharmacyCustomerType
  patientId             String?
  hospitalId            String
  customerName          String                @db.VarChar(150)
  customerPhone         String?               @db.VarChar(20)
  totalAmount           Decimal               @db.Decimal(12, 2)
  discountAmount        Decimal               @default(0.00) @db.Decimal(12, 2)
  payableAmount         Decimal               @db.Decimal(12, 2)
  paymentMode           PaymentMode           @default(CASH)
  receivedBy            String
  status                InvoiceStatus         @default(PAID)

  // Lifecycle Cancellations
  cancelledAt           DateTime?
  cancelledBy           String?
  cancellationReason    String?               @db.Text

  // Standard Metadata
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  createdBy             String?               @db.Uuid
  updatedBy             String?               @db.Uuid
  isDeleted             Boolean               @default(false)
  deletedAt             DateTime?
  deletedBy             String?               @db.Uuid

  // Relationships
  hospital              Hospital              @relation(fields: [hospitalId], references: [id], onDelete: Restrict)
  patient               Patient?              @relation(fields: [patientId], references: [id], onDelete: SetNull)
  recipient             Employee              @relation("PharmacyInvoiceReceivedBy", fields: [receivedBy], references: [id], onDelete: Restrict)
  canceller             Employee?             @relation("PharmacyInvoiceCancelledBy", fields: [cancelledBy], references: [id], onDelete: Restrict)
  items                 PharmacyInvoiceItem[]
  returns               PharmacyReturn[]      @relation("InvoiceReturns")
  payments              PharmacyInvoicePayment[]

  @@index([pharmacyInvoiceNumber])
  @@index([patientId])
  @@index([hospitalId])
  @@map("pharmacy_invoices")
}

model PharmacyInvoiceItem {
  id                String          @id @default(uuid())
  pharmacyInvoiceId String
  medicineId        String
  batchNumber       String          @db.VarChar(50)
  quantitySold      Int
  unitPrice         Decimal         @db.Decimal(12, 2)
  totalPrice        Decimal         @db.Decimal(12, 2)
  gstPercentage     Decimal         @db.Decimal(5, 2) @default(0.00)
  discountAmount    Decimal         @db.Decimal(12, 2) @default(0.00)

  // Standard Metadata
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  isDeleted         Boolean         @default(false)
  deletedAt         DateTime?
  deletedBy         String?         @db.Uuid

  // Relationships
  pharmacyInvoice   PharmacyInvoice @relation(fields: [pharmacyInvoiceId], references: [id], onDelete: Cascade)
  medicine          Medicine        @relation(fields: [medicineId], references: [id], onDelete: Restrict)

  @@map("pharmacy_invoice_items")
}

model PharmacyReturn {
  id                String          @id @default(uuid())
  pharmacyInvoiceId String
  returnNumber      String          @unique @db.VarChar(30)
  refundAmount      Decimal         @db.Decimal(12, 2)
  reason            String          @db.Text

  // Standard Metadata
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  createdBy         String?         @db.Uuid
  updatedBy         String?         @db.Uuid
  isDeleted         Boolean         @default(false)
  deletedAt         DateTime?
  deletedBy         String?         @db.Uuid

  // Relationships
  pharmacyInvoice   PharmacyInvoice @relation("InvoiceReturns", fields: [pharmacyInvoiceId], references: [id], onDelete: Restrict)
  items             PharmacyReturnItem[]

  @@index([returnNumber])
  @@map("pharmacy_returns")
}

model PharmacyInvoicePayment {
  id                String          @id @default(uuid())
  pharmacyInvoiceId String
  paymentMode       PaymentMode
  amount            Decimal         @db.Decimal(12, 2)

  // Relationships
  pharmacyInvoice   PharmacyInvoice @relation(fields: [pharmacyInvoiceId], references: [id], onDelete: Cascade)

  @@map("pharmacy_invoice_payments")
}

model PharmacyReturnItem {
  id                String          @id @default(uuid())
  pharmacyReturnId  String
  medicineId        String
  batchNumber       String          @db.VarChar(50)
  quantityReturned  Int
  refundRate        Decimal         @db.Decimal(12, 2)
  totalAmount       Decimal         @db.Decimal(12, 2)

  // Relationships
  pharmacyReturn    PharmacyReturn  @relation(fields: [pharmacyReturnId], references: [id], onDelete: Cascade)
  medicine          Medicine        @relation(fields: [medicineId], references: [id], onDelete: Restrict)

  @@map("pharmacy_return_items")
}

enum PharmacyAdjustmentType {
  DAMAGED
  EXPIRED
  LOST
  MANUAL_CORRECTION
}

model PharmacyStockAdjustment {
  id                String                 @id @default(uuid())
  medicineId        String
  batchNumber       String                 @db.VarChar(50)
  adjustmentType    PharmacyAdjustmentType
  stockBefore       Int
  quantity          Int
  stockAfter        Int
  reason            String                 @db.Text
  employeeId        String
  date              DateTime               @default(now())

  // Standard Metadata
  createdAt         DateTime               @default(now())
  createdBy         String?                @db.Uuid

  // Relationships
  medicine          Medicine               @relation(fields: [medicineId], references: [id], onDelete: Restrict)
  employee          Employee               @relation(fields: [employeeId], references: [id], onDelete: Restrict)

  @@map("pharmacy_stock_adjustments")
}

// ==========================================
// 11. PRINT ENGINE LAYOUT DESIGNS
// ==========================================

enum PrintTemplateStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model PrintTemplate {
  id           String              @id @default(uuid())
  templateKey  String              @db.VarChar(50)
  name         String              @db.VarChar(100)
  layoutJson   Json                @db.JsonB
  pageFormat   String              @db.VarChar(30)
  hospitalId   String
  documentType String              @db.VarChar(50)
  status       PrintTemplateStatus @default(DRAFT)
  version      Int                 @default(1)
  isPublished  Boolean             @default(false)
  category     String              @db.VarChar(50) @default("General")
  orientation  String              @db.VarChar(20) @default("PORTRAIT")
  margins      String              @db.VarChar(30) @default("15mm")
  copies       Int                 @default(1)
  language     String              @db.VarChar(20) @default("en")
  isSystemDefault Boolean          @default(false)
  thumbnailUrl String?             @db.Text

  // Standard Metadata
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  createdBy    String?             @db.Uuid
  updatedBy    String?             @db.Uuid
  isDeleted    Boolean             @default(false)
  deletedAt    DateTime?
  deletedBy    String?             @db.Uuid

  // Relationships
  hospital     Hospital            @relation(fields: [hospitalId], references: [id], onDelete: Restrict)
  histories    PrintHistory[]

  @@index([hospitalId])
  @@index([templateKey])
  @@map("print_templates")
}

model PrintHistory {
  id                String         @id @default(uuid())
  documentType      String         @db.VarChar(50)
  documentId        String         @db.VarChar(50)
  printedById       String
  printedAt         DateTime       @default(now())
  templateId        String?
  templateVersion   Int            @default(1)
  requestId         String?        @db.VarChar(50)
  printedFromModule String         @db.VarChar(50)
  brandingSnapshot  Json           @db.JsonB

  // Relationships
  printedBy         Employee       @relation("PrintedByEmployee", fields: [printedById], references: [id], onDelete: Cascade)
  template          PrintTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  @@map("print_histories")
}

// ==========================================
// 12. AUDITING SYSTEM LOGS
// ==========================================

model Audit {
  id            String    @id @default(uuid())
  timestamp     DateTime  @default(now())
  userId        String?
  clientIp      String?   @db.VarChar(45)
  action        String    @db.VarChar(50)
  resource      String?   @db.VarChar(100)
  entityId      String?   @db.Uuid
  requestId     String?   @db.VarChar(50)
  previousState Json?
  newState      Json?
  reason        String?   @db.Text
  description   String    @db.Text

  // Relationships
  user          Employee? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([timestamp])
  @@index([userId])
  @@index([action])
  @@index([resource, entityId])
  @@map("audits")
}

model PatientDeposit {
  id                 String           @id @default(uuid())
  patientId          String
  hospitalId         String
  opdConsultationId  String?
  amount             Decimal          @db.Decimal(12, 2)
  collectedBy        String           @db.Uuid
  transactionDate    DateTime         @default(now())
  isRefunded         Boolean          @default(false)
  
  // Standard Metadata
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  createdBy          String?          @db.Uuid
  updatedBy          String?          @db.Uuid
  isDeleted          Boolean          @default(false)
  deletedAt          DateTime?
  deletedBy          String?          @db.Uuid

  // Relationships
  patient            Patient          @relation(fields: [patientId], references: [id], onDelete: Restrict)
  hospital           Hospital         @relation(fields: [hospitalId], references: [id], onDelete: Restrict)
  opdConsultation    OPDConsultation? @relation(fields: [opdConsultationId], references: [id], onDelete: SetNull)
  allocations        PatientDepositAllocation[]

  @@map("patient_deposits")
}

model PatientDepositAllocation {
  id               String         @id @default(uuid())
  depositId        String
  invoiceId        String
  amountAllocated  Decimal        @db.Decimal(12, 2)
  transactionDate  DateTime       @default(now())
  
  // Standard Metadata
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  createdBy        String?        @db.Uuid
  updatedBy        String?        @db.Uuid
  isDeleted        Boolean        @default(false)
  deletedAt        DateTime?
  deletedBy        String?        @db.Uuid

  // Relationships
  deposit          PatientDeposit @relation(fields: [depositId], references: [id], onDelete: Restrict)
  invoice          Invoice        @relation(fields: [invoiceId], references: [id], onDelete: Restrict)

  @@index([depositId])
  @@index([invoiceId])
  @@map("patient_deposit_allocations")
}

model LabResultRevision {
  id                 String          @id @default(uuid())
  testOrderId        String
  revisionNumber     Int
  results            Json            // Snap array: [{ parameterName, parameterValue, referenceRange, unit }]
  remarks            String?         @db.Text
  technicianId       String?         @db.Uuid
  verifiedById       String?         @db.Uuid
  completedAt        DateTime
  completedBy        String
  editedAt           DateTime        @default(now())
  editedBy           String          @db.Uuid

  // Relationships
  testOrder          LabTestOrder    @relation(fields: [testOrderId], references: [id], onDelete: Cascade)

  @@index([testOrderId])
  @@map("lab_result_revisions")
}

model RadiologyFindingsRevision {
  id                 String              @id @default(uuid())
  scanOrderId        String
  revisionNumber     Int
  findings           String              @db.Text
  remarks            String?             @db.Text
  technicianId       String?             @db.Uuid
  verifiedById       String?             @db.Uuid
  completedAt        DateTime
  completedBy        String
  editedAt           DateTime            @default(now())
  editedBy           String              @db.Uuid

  // Relationships
  scanOrder          RadiologyScanOrder  @relation(fields: [scanOrderId], references: [id], onDelete: Cascade)

  @@index([scanOrderId])
  @@map("radiology_findings_revisions")
}
