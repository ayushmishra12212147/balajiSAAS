model ChargeCatalog {
  id              String           @id @default(uuid())
  code            String           @unique @db.VarChar(20)
  name            String           @db.VarChar(150)
  category        String           @db.VarChar(50)
  rate            Decimal          @db.Decimal(12, 2)

  // Standard Metadata
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  createdBy       String?          @db.Uuid
  updatedBy       String?          @db.Uuid
  isDeleted       Boolean          @default(false)
  deletedAt       DateTime?
  deletedBy       String?          @db.Uuid

  otType          OTType?

  // Relationships
  billableCharges BillableCharge[]
  otOperations    OperationTheater[] @relation("OTProcedureCatalog")

  @@map("charge_catalogs")
}

model BillableCharge {
  id              String                 @id @default(uuid())
  patientId       String
  chargeCatalogId String
  sourceModule    ChargeSourceModule
  sourceEntityId  String                 @db.Uuid
  quantity        Int                    @default(1)
  rate            Decimal                @db.Decimal(12, 2)
  totalAmount     Decimal                @db.Decimal(12, 2)
  billingStatus   BillingStatus          @default(PENDING)
  version         Int                    @default(1)

  // Standard Metadata
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  createdBy       String?                @db.Uuid
  updatedBy       String?                @db.Uuid
  isDeleted       Boolean                @default(false)
  deletedAt       DateTime?
  deletedBy       String?                @db.Uuid

  // Relationships
  patient         Patient                @relation(fields: [patientId], references: [id], onDelete: Restrict)
  chargeCatalog   ChargeCatalog          @relation(fields: [chargeCatalogId], references: [id], onDelete: Restrict)
  invoices        InvoiceChargeMapping[]

  @@index([patientId])
  @@index([billingStatus])
  @@index([sourceModule, sourceEntityId])
  @@index([patientId, createdAt])
  @@map("billable_charges")
}

model Invoice {
  id                 String                 @id @default(uuid())
  invoiceNumber      String                 @unique @db.VarChar(30)
  patientId          String
  hospitalId         String
  totalAmount        Decimal                @db.Decimal(12, 2)
  discountAmount     Decimal                @default(0.00) @db.Decimal(12, 2)
  discountPercentage Decimal?               @db.Decimal(5, 2)
  discountReason     String?                @db.Text
  discountApprovedBy String?                @db.Uuid
  payableAmount      Decimal                @db.Decimal(12, 2)
  paidAmount         Decimal                @default(0.00) @db.Decimal(12, 2)
  balanceAmount      Decimal                @db.Decimal(12, 2)
  paymentStatus      InvoiceStatus          @default(PENDING)
  version            Int                    @default(1)

  // Lifecycle Cancellations
  cancelledAt        DateTime?
  cancelledBy        String?
  cancellationReason String?                @db.Text

  // Standard Metadata
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  createdBy          String?                @db.Uuid
  updatedBy          String?                @db.Uuid
  isDeleted          Boolean                @default(false)
  deletedAt          DateTime?
  deletedBy          String?                @db.Uuid

  // Relationships
  hospital           Hospital               @relation(fields: [hospitalId], references: [id], onDelete: Restrict)
  patient            Patient                @relation(fields: [patientId], references: [id], onDelete: Restrict)
  canceller          Employee?              @relation("InvoiceCancelledBy", fields: [cancelledBy], references: [id], onDelete: Restrict)
  charges            InvoiceChargeMapping[]
  payments           Payment[]
  refunds            Refund[]
  depositAllocations PatientDepositAllocation[]

  @@index([invoiceNumber])
  @@index([patientId])
  @@index([paymentStatus])
  @@index([hospitalId])
  @@index([invoiceNumber, paymentStatus])
  @@index([patientId, createdAt])
  @@map("invoices")
}

model InvoiceChargeMapping {
  id               String         @id @default(uuid())
  invoiceId        String
  billableChargeId String

  // Standard Metadata
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  isDeleted        Boolean        @default(false)
  deletedAt        DateTime?
  deletedBy        String?        @db.Uuid

  invoice          Invoice        @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  billableCharge   BillableCharge @relation(fields: [billableChargeId], references: [id], onDelete: Cascade)

  @@unique([invoiceId, billableChargeId])
  @@map("invoice_charge_mappings")
}

model Payment {
  id                   String    @id @default(uuid())
  invoiceId            String
  amountPaid           Decimal   @db.Decimal(12, 2)
  paymentMode          PaymentMode
  transactionReference String?   @db.VarChar(100)
  transactionGroupId   String?   @db.VarChar(50)
  receivedAt           DateTime  @default(now())
  receivedBy           String
  version              Int       @default(1)

  // Standard Metadata
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  createdBy            String?   @db.Uuid
  updatedBy            String?   @db.Uuid
  isDeleted            Boolean   @default(false)
  deletedAt            DateTime?
  deletedBy            String?   @db.Uuid

  // Relationships
  invoice              Invoice   @relation(fields: [invoiceId], references: [id], onDelete: Restrict)
  recipient            Employee  @relation("PaymentReceivedBy", fields: [receivedBy], references: [id], onDelete: Restrict)
  refunds              Refund[]

  @@index([invoiceId])
  @@index([receivedAt])
  @@index([createdAt])
  @@map("payments")
}

model Refund {
  id             String    @id @default(uuid())
  invoiceId      String
  paymentId      String?
  amountRefunded Decimal   @db.Decimal(12, 2)
  refundReason   String    @db.Text
  refundedAt     DateTime  @default(now())
  refundedBy     String

  // Standard Metadata
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  createdBy      String?   @db.Uuid
  updatedBy      String?   @db.Uuid
  isDeleted      Boolean   @default(false)
  deletedAt      DateTime?
  deletedBy      String?   @db.Uuid

  // Relationships
  invoice        Invoice   @relation(fields: [invoiceId], references: [id], onDelete: Restrict)
  payment        Payment?  @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  manager        Employee  @relation("RefundProcessedBy", fields: [refundedBy], references: [id], onDelete: Restrict)

  @@index([invoiceId])
  @@index([refundedAt])
  @@index([createdAt])
  @@map("refunds")
}

